# Dependencies
node_modules/
.npm/

# Remotion build outputs
creatives/remotion-project/my-ads/out/
creatives/remotion-project/my-ads/.cache/
creatives/remotion-project/my-ads/dist/

# Rendered ad files (large binary files — don't commit MP4s/PNGs)
creatives/rendered/
!creatives/rendered/.gitkeep

# User-provided assets in public/ (music, images — too large for git)
creatives/remotion-project/my-ads/public/*.mp3
creatives/remotion-project/my-ads/public/*.jpg
creatives/remotion-project/my-ads/public/*.png
creatives/remotion-project/my-ads/public/*.mp4

# Archive folder (past project outputs — not part of the clean template)
_archive/

# External skills (installed per-machine via `npx skills add`) — not committed
.agents/skills/
# Keep .agents/ directory structure itself but not the skill contents
!.agents/.gitkeep

# Dynamic assets — campaign-specific, too large for git
assets/dynamic/*/
!assets/dynamic/README.md
!assets/dynamic/.gitkeep

# Static assets — committed (SFX library, brand files)
# Exception: raw/large media files if added to static
assets/static/overlays/*.mp4
assets/static/overlays/*.mov

# Environment / secrets
.env
.env.local
.env.*.local
*.env

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Temp files
/tmp/
*.tmp

# Raw ad library data can be large — optionally ignore
# research/ad-library-data/*.json
# research/ad-library-data/*.csv

# ── PRODUCT-SPECIFIC CONTENT (never push) ─────────────────────────────────────

# Per-product state (filled by agents; templates live as *.template)
state/current-cycle.md
state/system-log.md
state/product-context.md
state/outputs/current.md
state/orchestrator-notes.md
state/approvals/pending-approval.md

# Per-product research
research/*.md
!research/README.md

# Per-product briefs — dated folders only; category .gitkeep scaffolding remains
briefs/**/20*/

# Per-product review docs — dated folders only
creatives/review/**/20*/

# Per-product Remotion compositions (live in src/campaigns/, not committed)
creatives/remotion-project/my-ads/src/campaigns/

# Per-product media in public/ (product logos, b-roll, chat screenshots, scene clips)
creatives/remotion-project/my-ads/public/iktara*
creatives/remotion-project/my-ads/public/*_b_roll*
creatives/remotion-project/my-ads/public/*_B_Roll*
creatives/remotion-project/my-ads/public/bgm*
creatives/remotion-project/my-ads/public/b00*-scene*.mp4
creatives/remotion-project/my-ads/public/*-chat-*.png
creatives/remotion-project/my-ads/public/*-answer*.png

# Per-product brand asset folders (may contain spaces in name)
assets/iktara\ general\ assets/
"assets/iktara general assets/"

# QC output artefacts (generated at runtime, never committed)
scripts/qc/frames/
scripts/qc/qc.json
scripts/qc/spectrogram.png

# ── HIGGSFIELD INTEGRATION (never push) ───────────────────────────────────────

# Persistent Playwright Chrome profile (session cookies, etc.)
.playwright-profile/

# API credentials (contains key + secret)
scripts/higgsfield/*.local.env
scripts/higgsfield/higgsfield.local.env

# Per-brief chunk manifests and generation reports (live next to gitignored briefs)
**/ugc-chunks.json
**/ugc-chunks-report.json

# Last-frame images used for character chaining (extracted at runtime)
**/chunk-*-last.jpg

# Downloaded UGC clips (already covered by public/ rules above, belt-and-braces)
creatives/remotion-project/my-ads/public/campaigns/
